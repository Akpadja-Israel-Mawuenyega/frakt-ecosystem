# This is an example .env file for the Cadence Study Planner project.
# Rename this file to .env.local and update the values accordingly. Do not commit your .env.local file to version control, as it may contain sensitive information.

MONGODB_URI= "mongodb+srv://<username>:<password>@cluster0.tgpoq.mongodb.net/?appName=Cluster0" # Update <username> and <password> with your MongoDB credentials. Ensure that the URI is properly formatted and that your MongoDB cluster is accessible.
AI_PROVIDER=groq # Set the AI provider to "groq". If you want to use a different provider, update this value accordingly (e.g., "openai").
GROQ_API_KEY=<your_groq_api_key> # Replace <your_groq_api_key> with your actual GROQ API key. You can change this to match your preferred AI provider (e.g., "OPENAI_API_KEY"). Keep this key secure and do not share it publicly.
NEXT_PUBLIC_BASE_URL="http://localhost:<port>" # Update <port> to the port number your Next.js app is running on (default is 3000).
NEXTAUTH_URL="http://localhost:<port>" # Update <port> to match the port used in NEXT_PUBLIC_BASE_URL. This URL is used for authentication API routes.
NEXTAUTH_SECRET=<your_nextauth_secret> # Replace <your_nextauth_secret> with a secure random string. This secret is used to encrypt session data and should be kept confidential.
GOOGLE_CLIENT_ID=<your_google_client_id> # If you plan to use Google OAuth for authentication, replace <your_google_client_id> with your actual Google Client ID. Otherwise, you can leave this blank.
GOOGLE_CLIENT_SECRET=<your_google_client_secret> # If you plan to use Google OAuth for authentication, replace <your_google_client_secret> with your actual Google Client Secret. Otherwise, you can leave this blank.
ACADEMIC_YEAR="YYYY/YYYY" # Format: YYYY/YYYY (e.g., 2025/2026). Update this according to the current academic calendar.
SEMESTER=<number> # Replace <number> with the current semester number (1 for first semester, 2 for second semester, etc.). Keep in mind that the academic year and semester should be updated according to the current academic calendar.

# ───────────────────────────── FRAKT INTEGRATION (optional) ─────────────────────────────
# Frakt is a standalone analytics microservice that renders progress/velocity charts and
# admin traffic analytics as SVGs. If these are left unset, Cadence still works — chart
# sections simply render an empty/unavailable state. Run `node scripts/setup-frakt.mjs`
# from cadence_study_planner/ to register Cadence as a Frakt customer, store the chart
# template in Frakt's database, and print these values.
FRAKT_API_URL="http://127.0.0.1:8000" # Base URL of the running Frakt service (no trailing slash).
FRAKT_API_KEY=<your_frakt_api_key> # API key returned once when registering the Cadence customer with Frakt. Keep this secret.
FRAKT_CHART_TEMPLATE=cadence_line_forecast_v1 # Name of the SVG template registered with Frakt for Cadence's charts.