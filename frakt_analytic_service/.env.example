# =============================================================================
# FRAKT API - INFRASTRUCTURE CONFIGURATION
# =============================================================================

# --- PERSISTENCE LAYER (SQLAlchemy / MariaDB) ---
# LOCAL: For XAMPP/WAMP native execution.
# DOCKER: For containerized deployment.
LOCAL_DATABASE_URL="mysql+pymysql://frakt_username:frakt_password@127.0.0.1:3306/frakt_db"
DOCKER_DATABASE_URL="mysql+pymysql://frakt_username:frakt_password@host.docker.internal:3306/frakt_db"

# --- OBSERVABILITY & LOGGING ---
# Directory for all subsystem logs (Gateway + Worker).
LOG_DIR="logs"
GATEWAY_LOG_FILE="frakt_gateway.log"
WORKER_LOG_FILE="frakt_worker.log"

# --- INTER-PROCESS COMMUNICATION (IPC) ---
# Global Override (Recommended for Docker: "worker:8008")
WORKER_URL=

# Windows-Specific Override (Default: "127.0.0.1:8008")
WORKER_SOCKET_PATH=